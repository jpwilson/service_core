# ServiceCore Environment Variables
# Copy this to .env.local and fill in your values

# OpenRouter (required for AI chatbot)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Supabase (optional — app falls back to mock data without these)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Langfuse AI Tracing (optional — tracing disabled without these)
LANGFUSE_PUBLIC_KEY=your_langfuse_public_key_here
LANGFUSE_SECRET_KEY=your_langfuse_secret_key_here

# Sentry Error Monitoring (optional — error monitoring disabled without this)
VITE_SENTRY_DSN=https://your-dsn@sentry.io/your-project-id
